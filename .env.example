# DeepSeek / OpenAI（推荐）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=deepseek-chat

# 或本地 Ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b

# 可选：OCR（PaddleOCR API）
PADDLEOCR_API_URL=
PADDLEOCR_API_KEY=

# 可选：MCP 工具链
MCP_ENABLED=false
MCP_SERVER_COMMAND=

# 可选：时区偏移（默认 +8 北京时间）
TZ_OFFSET=8
